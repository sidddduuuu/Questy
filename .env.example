# Production should provide these explicitly. Local development can reuse the
# authenticated Nexla CLI credentials without copying secrets into this repo.
NEXLA_API_URL=
NEXLA_ACCESS_TOKEN=
NEXLA_CUSTOMER_MAP_ID=5561
ZERO_RUNNER=
ZERO_MAX_PAY=0.01
ZERO_PLANNER_MAX_PAY=0.02

# Match the iss/aud claims on Pomerium's signed JWT assertion. The Pomerium
# route must enable pass_identity_headers and forward a customer_id claim.
POMERIUM_ISSUER=
POMERIUM_AUDIENCE=
POMERIUM_ADMIN_GROUP=questloop-admin
